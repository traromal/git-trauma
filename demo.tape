Output assets/demo.gif

# Settings
Set FontSize 16
Set Theme Dracula
Set Width 100
Set Height 30
Set Padding 24
Set Framerate 15

# Show help
Type "git-trauma --help" 50ms
Sleep 2s
Enter

Sleep 2s
Ctrl+L

# Run analysis in a repo
Type "git-trauma --no-llm" 30ms
Sleep 1s
Enter

Sleep 3s
Ctrl+L

# Show worst command
Type "git-trauma worst --count 3" 30ms
Sleep 1s
Enter

Sleep 3s
Ctrl+L

# Show stats
Type "git-trauma stats" 30ms
Sleep 1s
Enter

Sleep 3s
